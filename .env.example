NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_APP_NAME=Hardware POS System
# Base URL used in reset links sent by email.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: set these to reuse a fixed Ethereal inbox.
# If omitted, the app creates a temporary Ethereal account at runtime.
ETHEREAL_HOST=smtp.ethereal.email
ETHEREAL_PORT=587
ETHEREAL_USER=
ETHEREAL_PASS=

# Optional sender display value for reset emails.
MAIL_FROM=no-reply@futurahardware.local

# Strong random secret used to sign reset tokens.
PASSWORD_RESET_SECRET=change-me-to-a-long-random-secret
